{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "maven-packager-desktop",
  "version": "1.3.2",
  "identifier": "com.local.mavenpackager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Maven Packager",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyQTMwQ0Y4MzUwQjU3OEEKUldTS1Z3czErQXlqTXU3OVV3Tm8xclhQOUR5WVdkVDh0TEloLzYrd3dOWnViTVdObGlEcUdxb1kK",
      "endpoints": [
        "https://github.com/fenggeg/maven-packager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "maven-packager-desktop",
  "version": "0.1.0",
  "identifier": "com.local.mavenpackager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Maven Packager",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    // 只打包 Windows 三大常用格式：msi + exe + portable
    "targets": ["msi", "exe", "portable"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      // 开启 wix = 才能正常编译 MSI（关键！）
      "wix": true
    }
  }
}